# Environment
NODE_ENV=development
PORT=3000

# Database (Choreo Managed PostgreSQL)
DB_HOST=localhost
DB_NAME=mttr_db
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
# How long to wait for a free client from the pool before erroring out.
# Prevents requests from hanging indefinitely when the DB is unreachable.
DB_POOL_CONNECT_MS=10000
# How long an idle client can sit in the pool before being closed (ms).
# Must be shorter than the server-side idle timeout on Choreo Postgres
# (~60s) — otherwise pg hands out a connection the server has already
# reaped and the next query fails with ECONNRESET.
DB_POOL_IDLE_MS=30000
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_PORT=5432
DB_SSL=false
# Postgres-side per-query deadline (SET statement_timeout, ms). Any query
# running longer than this is cancelled server-side and its pool client
# returns to the pool. Must sit above every legitimate query duration —
# aggregation ~10s, retention ~30s per full run; 2 min gives comfortable
# headroom. Raise if the workload ever grows past that.
DB_STATEMENT_TIMEOUT_MS=120000
DB_USER=mttr_user

# Authentication (Asgardeo/Choreo)
AUTH_AUDIENCE=<choreo-app-client-id>
AUTH_ENABLED=false
AUTH_ISSUER=https://api.asgardeo.io/t/<org>/oauth2/token
AUTH_JWKS_URI=https://api.asgardeo.io/t/<org>/oauth2/jwks

# CORS
# Comma-separated list of allowed origins. Applied in every environment
# except NODE_ENV=development and NODE_ENV=test (which allow any origin
# for easier local iteration). Leave empty to block all cross-origin
# browsers in restricted environments (server-to-server callers are
# unaffected — they don't send an Origin header).
CORS_ALLOWED_ORIGINS=

# Aggregation Job
AGGREGATION_CRON=0 0 * * *
AGGREGATION_ROLLING_MONTHS=12
MIN_SAMPLE_SIZE=20

# Data Retention
# How many months of raw case_events are kept before the retention job
# summarises them into case_events_summary and deletes the raw rows.
# Must exceed AGGREGATION_ROLLING_MONTHS with margin (see retentionService.js).
RETENTION_CASE_EVENTS_MONTHS=24
# How long batch-ingest audit rows are kept in ingestion_log.
RETENTION_INGESTION_LOG_DAYS=14

# Rate Limiting
# Runaway-loop safety net (Choreo's gateway handles per-customer quotas).
# 1000 req / 15 min accommodates ~80 concurrent dashboard viewers behind
# the SN OAuth client while still catching accidental infinite loops.
# Window is in milliseconds: 900000 ms = 15 min.
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_LEVEL=info
